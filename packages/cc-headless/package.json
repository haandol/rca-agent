{
  "name": "@org/cc-headless",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/handler.ts",
    "test": "vitest run",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.800.0",
    "@aws-sdk/client-s3": "^3.800.0",
    "@aws-sdk/client-sns": "^3.800.0",
    "@aws-sdk/client-sqs": "^3.800.0",
    "@aws-sdk/s3-request-presigner": "^3.800.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsx": "^4.19.0",
    "typescript": "~5.9.2",
    "vitest": "^3.0.0"
  }
}
