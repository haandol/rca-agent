# Model configuration
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-6
BEDROCK_HAIKU_MODEL_ID=global.anthropic.claude-haiku-4-5-20251001-v1:0
AWS_REGION=us-east-1
BEDROCK_MAX_TOKENS=4096
BEDROCK_HAIKU_MAX_TOKENS=4096

# Adaptive thinking feature flag
THINKING_ENABLED=false

# Timeouts
SCOPING_TIMEOUT_SECONDS=300
HYPOTHESIS_GENERATION_TIMEOUT_SECONDS=180
HYPOTHESIS_GENERATION_MAX_RETRIES=3
LLM_DEFAULT_TIMEOUT_SECONDS=120

# RCA loop limits
RCA_TIME_BUDGET_SECONDS=1200
RCA_MAX_TREE_DEPTH=5
RCA_MAX_VALIDATION_LOOPS=3
RCA_MAX_REGENERATION_ROUNDS=2

# Thresholds
CONFIRMATION_THRESHOLD=0.8
REJECTION_THRESHOLD=0.3
TERMINATION_CONFIDENCE_THRESHOLD=0.9
MAX_BRANCHING_DEPTH=3

# Playbook
PLAYBOOK_SIMILARITY_THRESHOLD=0.7
PLAYBOOK_UPDATE_THRESHOLD=0.86
PLAYBOOK_TOP_K=3

# AWS resources (set per environment)
# S3_VECTOR_BUCKET_NAME=
# S3_VECTOR_PLAYBOOK_INDEX=playbook-index
# S3_EVIDENCE_BUCKET=
# S3_REPORT_BUCKET=
# SNS_NOTIFICATION_TOPIC_ARN=

# SQS worker
# SQS_QUEUE_URL=
# SQS_POLL_WAIT_SECONDS=20
