{
  "name": "infra",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/infra",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm tsc",
        "cwd": "packages/infra"
      }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm cdk deploy \"*\" --require-approval never --concurrency 4",
        "cwd": "packages/infra"
      }
    },
    "diff": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm cdk diff",
        "cwd": "packages/infra"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm jest",
        "cwd": "packages/infra"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm eslint .",
        "cwd": "packages/infra"
      }
    }
  }
}
